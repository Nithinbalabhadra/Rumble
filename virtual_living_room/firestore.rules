rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      allow read, write: if request.auth != null;
      match /players/{uid} {
        allow read, update, create: if request.auth.uid == uid;
      }
    }
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read: if false;
    }
  }
}
